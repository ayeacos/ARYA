<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head') %>

    <body>

        <%- include('../partials/header') %>

            <main>

                <section class="login">

                    <h2>Iniciar Sesión</h2>

                    <form action="/login" method="POST">

                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="Ingresá tu email"
                            value="<%= old ? old.email : '' %>">

                        <% if (typeof errors !=='undefined' && errors.email) { %>
                            <p style="color:red;">
                                <%= errors.email.msg %>
                            </p>
                        <% } %>

                        <label for="password">Contraseña</label>
                        <input type="password" id="password" name="password" placeholder="Ingresá tu contraseña">

                        <% if (typeof errors !=='undefined' && errors.password) { %>
                            <p style="color:red;">
                                 <%= errors.password.msg %>
                            </p>
                        <% } %>

                        <div class="login-options">
                            <label>
                            <input type="checkbox">
                            Recordarme
                            </label>

                            <a href="#">¿Olvidaste tu contraseña?</a>
                        </div>

                        <button type="submit">Ingresar</button>

                        <p>
                        ¿No tenés cuenta?
                        <a href="/register">Crear cuenta</a>
                        </p>

                    </form>

                </section>

            </main>

            <%- include('../partials/footer') %>
            
    <script src="/js/loginValidation.js"></script>

    </body>

</html>