<!DOCTYPE html>
<html lang="es">

<head>
    <%- include('../partials/head') %>
</head>

<body>

    <%- include('../partials/header') %>

        <main>

            <section class="login">

                <h2>Mi Perfil</h2>

                <p>Nombre: <%= user.firstName %>
                </p>

                <p>Apellido: <%= user.lastName %>
                </p>

                <p>Email: <%= user.email %>
                </p>

                <a href="/logout">
                    <button>Cerrar sesión</button>
                </a>

                <p>Categoría: <%= user.category %>
                </p>

                <img src="/images/users/<%= user.image %>" alt="Perfil" width="200">

            </section>

        </main>

        <%- include('../partials/footer') %>

</body>

</html>