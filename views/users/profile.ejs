<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head') %>

    <body>

        <%- include('../partials/header') %>

            <main>

                <section class="login">

                    <h2>Mi Perfil</h2>

                    <p>Nombre: <%= user.first_name %>
                    </p>

                    <p>Apellido: <%= user.last_name %>
                    </p>

                    <p>Email: <%= user.email %>
                    </p>

                    <a href="/profile/edit">
                        <button>Editar perfil</button>
                    </a>

                    <a href="/logout">
                        <button>Cerrar sesión</button>
                    </a>

                    <p>Categoría: <%= user.category %>
                    </p>

                    <img src="/images/users/<%= user.image %>" alt="Perfil" width="200">

                </section>

            </main>

            <%- include('../partials/footer') %>

    </body>

</html>