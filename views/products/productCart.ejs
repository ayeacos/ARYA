<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head') %>

<body>

<%- include('../partials/header') %>

    <main>
        <section class="cart">

            <h2>Mi Carrito</h2>

            <div class="cart-item">

                <img src="/img/vela-vainilla.png" alt="Vela Vainilla">

                <div class="cart-info">
                    <h3>Vela Vainilla</h3>
                    <p>Cera de soja natural</p>
                </div>

                <div class="cart-quantity">
                    <button>-</button>
                    <span>1</span>
                    <button>+</button>
                </div>

                <p class="cart-price"> $18.500</p>

            </div>

            <div class="cart-total">
                <h3>Total</h3>
                <p>$18.500</p>
            </div>

            <div class="cart-buttons">
                <button class="secondary-btn">Continuar comprando</button>
                <button>Finalizar compra</button>
            </div>

        </section>
    </main>
    
    <%- include('../partials/footer') %>

</body>

</html>