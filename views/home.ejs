<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="favicon.ico" type="image/x-icon">
    <title>ARYA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <header>
        <h1 class="logo">ARYA</h1>

        <nav>
            <a href="index.html">Inicio</a>
            <a href="#">Colecciones</a>
            <a href="login.html">Ingresar</a>
            <a href="register.html">Crear cuenta</a>
            <a href="productCart.html">Carrito</a>
        </nav>
    </header>

    <main>
        <section class="hero">

            <div class="hero-text">
                <p class="hero-tag">VELAS ARTESANALES</p>
                <h2>Transformá los pequeños<br>
                    momentos cotidianos en<br>
                    experiencias especiales.</h2>

                <p>
                    Velas artesanales pensadas para acompañar momentos de bienestar,
                    calma y conexión con el hogar.
                </p>

                <button>Descubrir Colección</button>
            </div>

            <div class="hero-image">
                <img src="/img/vela-home.png" alt="Vela artesanal ARYA">
            </div>
        </section>

        <section class="categorias">

            <h2>Categorías</h2>

            <div class="categorias-grid">

                <article class="categoria-card">
                    <img src="/img/vela-cocolima.png" class="img-aromatica" alt="Velas aromáticas">
                    <h3>Aromáticas</h3>
                </article>

                <article class="categoria-card">
                    <img src="/img/velas-escultoricas.jpeg" class="img-escultorica" alt="Velas escultóricas">
                    <h3>Velas Escultóricas</h3>
                </article>

                <article class="categoria-card">
                    <img src="/img/giftbox.jpg" alt="Gift Box">
                    <h3>Gift Box</h3>
                </article>

                <article class="categoria-card">
                    <img src="/img/edicion-limitada.png" class="img-edicion-limitada" alt="Edición Limitada">
                    <h3>Edición Limitada</h3>
                </article>

            </div>

        </section>

        <section class="destacados">

            <h2>Productos Destacados</h2>

            <div class="productos-grid">

                <article class="producto-card">
                    <img src="/img/vela-vainilla.png" class="img-vainilla" alt="Vainilla">
                    <h3>Vainilla</h3>
                    <p>$18.500</p>
                    <button>Ver producto</button>
                </article>

                <article class="producto-card">
                    <img src="/img/sandia-pepino.png" alt="Sandía y Pepino">
                    <h3>Sandía & Pepino</h3>
                    <p>$19.500</p>
                    <button>Ver producto</button>
                </article>

                <article class="producto-card">
                    <img src="/img/box-deseos.png" alt="Gift Box">
                    <h3>Gift Box Deseos</h3>
                    <p>$35.000</p>
                    <button>Ver producto</button>
                </article>

                <article class="producto-card">
                    <img src="/img/gift-box.jpg" alt="Edición Especial">
                    <h3>Edición Especial</h3>
                    <p>$22.000</p>
                    <button>Ver producto</button>
                </article>

            </div>

        </section>

        <section class="beneficios">

            <h2>¿Por qué elegir ARYA?</h2>

            <div class="beneficios-grid">

                <div class="beneficio">
                    <p>Cera de soja 100% natural</p>
                </div>

                <div class="beneficio">
                    <p>Envases reutilizables</p>
                </div>

                <div class="beneficio">
                    <p>Elaboración artesanal</p>
                </div>

                <div class="beneficio">
                    <p>Aromas intensos y mayor duración</p>
                </div>

                <div class="beneficio">
                    <p>Diseñadas para regalar y disfrutar</p>
                </div>

            </div>

        </section>

        <section class="historia">

            <div class="historia-img">
                <img src="/img/vela-historia.png" alt="Historia ARYA">
            </div>

            <div class="historia-text">
                <h2>Nuestra Historia</h2>

                <p>
                    ARYA nació del deseo de transformar pequeños momentos cotidianos
                    en experiencias especiales.<br>
                    Cada vela es elaborada artesanalmente con cera de soja natural,
                    cuidando cada detalle para crear ambientes cálidos y memorables.
                </p>

                <button>Conocé más</button>

            </div>

        </section>

    </main>

    <footer class="footer">

        <div class="footer-container">

            <div class="footer-column">
                <h3>ARYA</h3>
                <p>Velas artesanales elaboradas con cera de soja natural para crear
                    momentos de bienestar, calma y conexión.
                </p>

                <div class="social-links">
                    <a href="#">Instagram</a>
                    <a href="#">Pinterest</a>
                    <a href="#">Facebook</a>
                </div>
            </div>

            <div class="footer-column">
                <h3>Colecciones</h3>
                <a href="#">Aromáticas</a>
                <a href="#">Escultóricas</a>
                <a href="#">Gift Box</a>
                <a href="#">Edición Limitada</a>
            </div>

            <div class="footer-column">
                <h3>Nuestra historia</h3>
                <a href="#">Sobre ARYA</a>
                <a href="#">Blog</a>
                <a href="#">Contacto</a>
            </div>

            <div class="footer-column">
                <h3>Ayuda</h3>
                <a href="#">Preguntas frecuentes</a>
                <a href="#">Envíos</a>
                <a href="#">Devoluciones</a>
            </div>

            <div class="footer-column footer-newsletter">

                <h3>Newsletter</h3>
                <p>
                    Suscribite para recibir novedades, lanzamientos y promociones exclusivas.
                </p>
                <input type="email" placeholder="Tu email">
                <button>Suscribirme</button>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© 2026 ARYA. Todos los derechos reservados.</p>

            <div>
                <a href="#">Privacidad</a>
                <a href="#">Términos</a>
                <a href="#">Cookies</a>
            </div>
        </div>

    </footer>


</body>

</html>